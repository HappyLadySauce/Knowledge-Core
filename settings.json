{
  "insecure": {
    "bind-address": "${KNOWLEDGE_CORE_BIND_ADDRESS}",
    "bind-port": "${KNOWLEDGE_CORE_BIND_PORT}",
    "trusted-proxies": "${KNOWLEDGE_CORE_TRUSTED_PROXIES_JSON}"
  },
  "database": {
    "url": "${KNOWLEDGE_CORE_DATABASE_URL}",
    "max-open-conns": "${KNOWLEDGE_CORE_DATABASE_MAX_OPEN_CONNS}",
    "max-idle-conns": "${KNOWLEDGE_CORE_DATABASE_MAX_IDLE_CONNS}",
    "conn-max-lifetime": "${KNOWLEDGE_CORE_DATABASE_CONN_MAX_LIFETIME}"
  },
  "redis": {
    "enabled": "${KNOWLEDGE_CORE_REDIS_ENABLED}",
    "required": "${KNOWLEDGE_CORE_REDIS_REQUIRED}",
    "url": "${KNOWLEDGE_CORE_REDIS_URL}",
    "key-prefix": "${KNOWLEDGE_CORE_REDIS_KEY_PREFIX}",
    "pool-size": "${KNOWLEDGE_CORE_REDIS_POOL_SIZE}",
    "dial-timeout": "${KNOWLEDGE_CORE_REDIS_DIAL_TIMEOUT}",
    "read-timeout": "${KNOWLEDGE_CORE_REDIS_READ_TIMEOUT}",
    "write-timeout": "${KNOWLEDGE_CORE_REDIS_WRITE_TIMEOUT}"
  },
  "jwt": {
    "secret": "${KNOWLEDGE_CORE_JWT_SECRET}",
    "access-ttl": "${KNOWLEDGE_CORE_JWT_ACCESS_TTL}",
    "refresh-ttl": "${KNOWLEDGE_CORE_JWT_REFRESH_TTL}"
  },
  "websocket": {
    "allowed-origins": "${KNOWLEDGE_CORE_WEBSOCKET_ALLOWED_ORIGINS_JSON}"
  }
}
