{
  "insecure": {
    "bind-address": "${KNOWLEDGE_CORE_BIND_ADDRESS}",
    "bind-port": "${KNOWLEDGE_CORE_BIND_PORT}",
    "trusted-proxies": "${KNOWLEDGE_CORE_TRUSTED_PROXIES_JSON}"
  },
  "jwt": {
    "secret": "${KNOWLEDGE_CORE_JWT_SECRET}",
    "access-ttl": "${KNOWLEDGE_CORE_JWT_ACCESS_TTL}",
    "refresh-ttl": "${KNOWLEDGE_CORE_JWT_REFRESH_TTL}"
  },
  "library": {
    "path": "${KNOWLEDGE_CORE_LIBRARY_PATH}"
  }
}
